# CrewMate 프론트엔드 환경 변수 예시 (.env.local 또는 .env.production 으로 복사)

# API 모드: mock(백엔드 없이 데모) | real(실제 API Gateway 호출)
VITE_API_MODE=real

# API Gateway 베이스 URL — 반드시 스테이지 경로(/dev 등)까지 포함한다.
# sam deploy 출력값 ApiUrl 을 그대로 사용:
#   https://<api-id>.execute-api.ap-northeast-2.amazonaws.com/dev
VITE_API_BASE_URL=https://your-api-id.execute-api.ap-northeast-2.amazonaws.com/dev

# (하위호환) 구 변수명도 인식된다. 신규 설정은 VITE_API_BASE_URL 사용 권장.
# VITE_API_URL=https://your-api-id.execute-api.ap-northeast-2.amazonaws.com/dev
